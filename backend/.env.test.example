# Test environment for E2E tests.
# Copy values from your real .env where possible, but use TEST/SANDBOX accounts:
#   - DATABASE_URL: a dedicated test Postgres (Docker container or Neon branch)
#   - STRIPE_*: keys from a Stripe test mode account
#   - SUPABASE_URL: a separate Supabase project used only for tests
# Never reuse production secrets here.

NODE_ENV=test
PORT=8889

# CORS — must include the test web port (3100)
CORS_ORIGIN=http://localhost:3100

# Frontend URL (used in Stripe redirects)
FRONTEND_URL=http://localhost:3100

# Test database (must be empty / wipeable — DO NOT point at dev or prod DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/rejectcheck_test?schema=public

# Supabase test project (separate from dev/prod)
SUPABASE_URL=https://CHANGE_ME.supabase.co
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# AI providers — same keys as dev are fine, or use a separate test budget
ANTHROPIC_API_KEY=CHANGE_ME
OPENAI_API_KEY=
GEMINI_API_KEY=

# Stripe TEST MODE keys (sk_test_, whsec_ from Stripe CLI)
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_SHORTLISTED_PRICE_ID=price_CHANGE_ME
STRIPE_HIRED_PRICE_ID=price_CHANGE_ME

# Disable Sentry in tests
SENTRY_DSN=
