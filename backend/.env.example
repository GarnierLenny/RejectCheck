# Runtime
NODE_ENV=development
PORT=8888

# CORS — comma-separated list
CORS_ORIGIN=http://localhost:3000,https://rejectcheck.com,https://www.rejectcheck.com

# Frontend URL (used in Stripe redirects, emails)
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rejectcheck?schema=public

# Supabase auth (JWKS URL is derived as ${SUPABASE_URL}/auth/v1/.well-known/jwks.json)
SUPABASE_URL=https://xxxx.supabase.co

# AI providers
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI is optional — only used by interview.service.ts for TTS (audio.speech) and
# Whisper (audio.transcriptions). Without it, the Interview audio features are disabled.
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SHORTLISTED_PRICE_ID=price_...
STRIPE_HIRED_PRICE_ID=price_...
# Optional. Discounted recurring price on the SAME Hired product (Founder deal).
# Founder subs are stored as plan='hired'. Leave unset to hide the founder plan.
STRIPE_FOUNDER_PRICE_ID=price_...
# Credit packs use inline price_data (backend/src/credits/domain/credit-packs.ts) — no price id needed.

# RevenueCat (mobile in-app purchases). Optional — unset → the /api/revenuecat/webhook
# endpoint rejects every event (fail closed) but the backend still boots. Set this to
# the exact value RevenueCat sends in the webhook's Authorization header
# (RevenueCat dashboard → Project → Integrations → Webhooks → Authorization header value).
REVENUECAT_WEBHOOK_SECRET=

# Optional prompts (overrides)
SYSTEM_TECHNICAL_PROMPT=
CHALLENGE_GENERATION_PROMPT=

# Observability (optional)
SENTRY_DSN=

# ── Feature flags ─────────────────────────────────────────────────────────────
# Profile digest: cross-source synthesis (CV + LinkedIn + GitHub + portfolio)
# powering the Consistency + Timeline views. OFF by default. When unset/false,
# analyses run on the raw sources directly (GitHub dev-depth is unaffected —
# it flows in separately). Set to 'true' to re-enable the digest.
PROFILE_DIGEST_ENABLED=false

# CV review: feed the signed-in user's own profile portfolio (lennygarnier.com
# etc.) as a cross-check source. Fine when auditing your own CV; but when you
# review someone else's CV it surfaces YOUR portfolio as fake "identity
# mismatch" inconsistencies and leaks your data. OFF by default (opt-in), same
# safe default as the digest. Set to 'true' only for the audit-your-own-CV case.
CV_REVIEW_PORTFOLIO_ENABLED=false

# Owner "audit mode": comma-separated emails allowed to run lean, quota-free
# teaser audits (?audit=1) that auto-generate a public share link — for doing
# free CV audits for strangers (e.g. from Reddit) without burning quota or
# leaking your own profile. Non-owners requesting audit mode get a normal
# analysis. Unset → nobody has the mode.
OWNER_EMAILS=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Optional. Unset → emails are logged, not sent (safe default for dev/CI).
# Set EMAIL_ENABLED=true + a verified Resend domain to actually deliver.
EMAIL_ENABLED=false
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="RejectCheck <hello@send.rejectcheck.com>"
EMAIL_REPLY_TO=support@rejectcheck.com
# Public origin for email IMAGES + LINKS. Must be public HTTPS (Gmail's image
# proxy can't reach localhost). Falls back to FRONTEND_URL.
EMAIL_BASE_URL=https://rejectcheck.com
# This backend's public URL — used for the one-click unsubscribe link.
BACKEND_PUBLIC_URL=https://api.rejectcheck.com
# HMAC secret for unsubscribe tokens. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_UNSUBSCRIBE_SECRET=change-me-strong-random-hex
# Unlocks /api/email/dev in PROD via ?secret=<this>. Unset = dev-only (404 in prod).
EMAIL_DEV_SECRET=some-admin-secret
