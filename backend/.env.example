# Runtime
NODE_ENV=development
PORT=8888

# CORS — comma-separated list
CORS_ORIGIN=http://localhost:3000,https://rejectcheck.com,https://www.rejectcheck.com

# Frontend URL (used in Stripe redirects, emails)
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rejectcheck?schema=public

# Supabase auth (JWKS URL is derived as ${SUPABASE_URL}/auth/v1/.well-known/jwks.json)
SUPABASE_URL=https://xxxx.supabase.co

# AI providers
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI is optional — only used by interview.service.ts for TTS (audio.speech) and
# Whisper (audio.transcriptions). Without it, the Interview audio features are disabled.
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SHORTLISTED_PRICE_ID=price_...
STRIPE_HIRED_PRICE_ID=price_...

# Optional prompts (overrides)
SYSTEM_TECHNICAL_PROMPT=
CHALLENGE_GENERATION_PROMPT=

# Observability (optional)
SENTRY_DSN=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Optional. Unset → emails are logged, not sent (safe default for dev/CI).
# Set EMAIL_ENABLED=true + a verified Resend domain to actually deliver.
EMAIL_ENABLED=false
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="RejectCheck <hello@send.rejectcheck.com>"
EMAIL_REPLY_TO=support@rejectcheck.com
# Public origin for email IMAGES + LINKS. Must be public HTTPS (Gmail's image
# proxy can't reach localhost). Falls back to FRONTEND_URL.
EMAIL_BASE_URL=https://rejectcheck.com
# This backend's public URL — used for the one-click unsubscribe link.
BACKEND_PUBLIC_URL=https://api.rejectcheck.com
# HMAC secret for unsubscribe tokens. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_UNSUBSCRIBE_SECRET=change-me-strong-random-hex
