generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Waitlist {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Subscription {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  stripeCustomerId String
  plan             String
  status           String
  currentPeriodEnd DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([stripeCustomerId])
}

model Analysis {
  id               Int          @id @default(autoincrement())
  email            String?      // Registered users only
  ip               String?      // Anonymous tracking
  jobDescription   String?      // Registered users only
  jobLabel         String?      // User-defined label for easy identification
  company          String?      // AI-extracted company name
  jdLanguage       String?      // ISO 639-1 language code of job description
  cvText           String?      // Registered users only
  motivationLetter String?      // Registered users only
  result           Json?        // Registered users only
  createdAt        DateTime     @default(now())
  application      Application?

  @@index([email])
  @@index([ip])
}

model Application {
  id                  Int       @id @default(autoincrement())
  email               String
  jobTitle            String
  company             String
  status              String    @default("applied")
  appliedAt           DateTime  @default(now())
  notes               String?
  analysisId          Int?      @unique
  analysis            Analysis? @relation(fields: [analysisId], references: [id])
  seniority           String?
  pay                 String?
  officeLocation      String?
  workSetting         String?
  contractType        String?
  languagesRequired   String?
  yearsOfExperience   String?
  companyStage        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([email, jobTitle, company])
  @@index([email])
}

model Profile {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  username       String?
  avatarUrl      String?
  displayName    String?
  githubUsername String?
  linkedinUrl    String?
  coverLetterName String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SavedCv {
  id        Int      @id @default(autoincrement())
  email     String
  name      String
  url       String
  createdAt DateTime @default(now())

  @@index([email])
}

model InterviewAttempt {
  id         Int      @id @default(autoincrement())
  email      String
  analysisId Int
  transcript Json     // [{ role: 'ai'|'user', content: string, questionIndex: number }]
  analysis   Json?    // null until /complete is called
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([analysisId])
}
