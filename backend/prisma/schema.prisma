generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries go through Supabase's transaction-mode pooler
  // (Supavisor, port 6543) with `pgbouncer=true&connection_limit=N` so 1
  // backend Postgres connection is shared across many short-lived queries.
  url       = env("DATABASE_URL")
  // Migrations and introspection use a direct (or session-mode) connection
  // because transaction-pool mode doesn't support the session-level state
  // Prisma needs for those operations. Falls back to DATABASE_URL when unset.
  directUrl = env("DIRECT_URL")
}

enum SubscriptionPlan {
  shortlisted
  hired
}

enum SubscriptionStatus {
  active
  canceled
  incomplete
  incomplete_expired
  past_due
  trialing
  unpaid
  paused
}

enum SubscriptionProvider {
  stripe
  revenuecat
}

enum ApplicationStatus {
  interested
  applied
  interviewing
  offer
  rejected
}

// Real-world outcome the user reports for an analysis. Lightweight, per-analysis
// signal (distinct from the heavier Application tracker). Default `not_applied`
// because analyses are usually run BEFORE applying (analyze → fix → apply). Only
// the terminal states (no_response/interview/offer/rejected) feed score
// calibration; not_applied/applied are pending.
enum AnalysisOutcome {
  not_applied
  applied
  no_response
  interview
  offer
  rejected
}

enum CreditLedgerType {
  grant
  consume
}

enum CreditLedgerSource {
  purchase // Stripe one-time payment
  admin_grant // manual grant by admin (support, marketing)
  analysis // consumption tied to an analysis row
  refund // future: revoke credits on refund
}

model Waitlist {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Subscription {
  id               Int                  @id @default(autoincrement())
  email            String
  // Which billing provider wrote this row. Stripe = web, RevenueCat = mobile
  // IAP. One row per (email, provider) so a user can hold both simultaneously.
  provider         SubscriptionProvider @default(stripe)
  // Stripe customer id (Stripe rows only — null for RevenueCat).
  stripeCustomerId String?
  // Generic external id (RevenueCat app_user_id) for audit/lookup.
  externalRef      String?
  plan             SubscriptionPlan
  status           SubscriptionStatus
  currentPeriodEnd DateTime
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([email, provider])
  @@index([stripeCustomerId])
  @@index([provider, externalRef])
}

model Analysis {
  id                    Int                @id @default(autoincrement())
  email                 String? // Registered users only
  ip                    String? // Anonymous tracking
  jobDescription        String? // Registered users only
  jobLabel              String? // User-defined label for easy identification
  company               String? // AI-extracted company name
  jdLanguage            String? // ISO 639-1 language code of job description
  cvText                String? // Registered users only — whitespace-collapsed for LLM prompts
  cvTextFormatted       String? // Registered users only — newlines preserved for display/highlighting
  linkedinText          String? // Registered users only — whitespace-collapsed for LLM prompts
  linkedinTextFormatted String? // Registered users only — newlines preserved for display/highlighting
  githubInfo            String? // Registered users only
  motivationLetter      String? // Registered users only
  coverLetter           String? // Saved after HIRED-plan generation
  cvFileUrl             String? // Supabase Storage URL of the uploaded CV PDF (authenticated users only)
  liFileUrl             String? // Supabase Storage URL of the uploaded LinkedIn PDF
  mlFileUrl             String? // Supabase Storage URL of the uploaded motivation letter PDF
  shareToken            String?            @unique // Public share link token (generated on demand)
  claimToken            String?            @unique // Anonymous analyses: lets the user attach this analysis to their account at signup. Cleared on claim; row auto-deleted after a TTL if never claimed.
  result                Json? // Registered users only — hot pass fields (scores, audits without fixes, red flag titles, etc.)
  deepAnalysis          Json? // Cold path generated post-analysis_done (fixes, project_recommendation, technical_analysis, ats critical_missing_keywords). Null for legacy analyses where `result` already contains everything.
  negotiationAnalysis   Json? // HIRED-only negotiation playbook (market positioning, leverage, counter-offer, talking points, roadmap salary impact)
  starterRepo           Json? // SHORTLISTED+ — file tree generated by Gemini for the bridge project starter repo
  // Deterministic keyword-match snapshot (KeywordMatchResult) computed at
  // analysis time from the JD + full CV text. Baseline the re-scan loop diffs
  // against. Null for legacy rows — recomputed on demand from cvText + JD.
  keywordMatch          Json?
  // Full (paid) re-scan lineage: when this analysis is itself a re-scan of an
  // earlier one, points at the parent so the UI can show a before/after chain.
  parentAnalysisId      Int?
  parent                Analysis?          @relation("AnalysisLineage", fields: [parentAnalysisId], references: [id], onDelete: SetNull)
  children              Analysis[]         @relation("AnalysisLineage")
  completedSteps        Int[]              @default([]) // Bridge project step indices checked off by the user
  premiumUnlockedAt     DateTime? // One-time "unlock this CV" purchase: when set, the CV rewrite is unlocked for THIS analysis without a subscription. Set by the analysis_unlock Stripe webhook.
  rewriteCount          Int                @default(0) // CV rewrites generated for this analysis. Capped (REWRITE_REGEN_CAP) to bound LLM cost — applies to subscribers AND one-time unlocks.
  creditCost            Int                @default(100) // credits deducted from monthly allowance: 100 = analyze JD, 50 = CV audit
  outcome               AnalysisOutcome    @default(not_applied) // real-world result reported by the user (moat: calibrates the risk score against actual outcomes)
  outcomeUpdatedAt      DateTime? // when the user last set the outcome (null = never touched, still the default)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  application           Application?
  interviewAttempts     InterviewAttempt[]
  fixes                 AnalysisFix[]
  rescans               Rescan[]

  @@index([email])
  @@index([ip])
  // Covers /api/analyze/history (WHERE email = ? ORDER BY createdAt DESC).
  @@index([email, createdAt(sort: Desc)])
  @@index([parentAnalysisId])
}

// Lightweight, FREE keyword-only re-scan attempt. The retention loop: the user
// re-uploads a corrected CV, we re-run the DETERMINISTIC keyword match (no LLM,
// no credits) against the parent analysis's stored JD, and store the resulting
// coverage so the UI can plot the score climbing over successive attempts.
//
// Kept OUT of the Analysis table on purpose: quick re-scans are free and
// unlimited, so folding them into Analysis would bloat history and the monthly
// quota math. A full (paid) re-scan is a real Analysis row instead (see
// Analysis.parentAnalysisId).
model Rescan {
  id            Int      @id @default(autoincrement())
  analysisId    Int
  analysis      Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  // Deterministic coverage 0-100 at this attempt. Only rows with a computable
  // score are stored (a JD with no recognised skills can't be tracked).
  coverageScore Int
  matchedCount  Int
  totalCount    Int
  // Full KeywordMatchResult snapshot for the present/absent table + delta.
  keywordMatch  Json
  createdAt     DateTime @default(now())

  // Covers the per-analysis timeline (WHERE analysisId = ? ORDER BY createdAt).
  @@index([analysisId, createdAt])
}

// Per-issue fix blocks, generated lazily/in-parallel AFTER the hot diagnostic.
// One row per fix keyed by a STABLE issueKey (assigned in the hot pass) — this
// is deliberate (concurrency-audit rule R1): concurrent per-fix generations
// upsert their OWN row and never read-modify-write a shared JSON column, so a
// "generate all fixes" fan-out can't lose writes (last-writer-wins on a blob).
model AnalysisFix {
  id         Int      @id @default(autoincrement())
  analysisId Int
  issueKey   String // stable key from the hot pass (R2) — e.g. "cv-<hash>"
  scope      String // cv | github | linkedin | seniority | tone | redflag | project | ats
  fix        Json // the generated fix block (summary, steps, example, project_idea, time_required)
  createdAt  DateTime @default(now())
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@unique([analysisId, issueKey]) // idempotent upsert target — the whole point of R1
  @@index([analysisId])
}

model Application {
  id                Int               @id @default(autoincrement())
  email             String
  jobTitle          String
  company           String
  status            ApplicationStatus @default(applied)
  appliedAt         DateTime          @default(now())
  notes             String?
  analysisId        Int?              @unique
  analysis          Analysis?         @relation(fields: [analysisId], references: [id])
  seniority         String?
  pay               String?
  officeLocation    String?
  workSetting       String?
  contractType      String?
  languagesRequired String?
  yearsOfExperience String?
  companyStage      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([email, jobTitle, company])
  @@index([email])
  // Covers /api/applications (WHERE email = ? ORDER BY appliedAt DESC).
  @@index([email, appliedAt(sort: Desc)])
}

model Profile {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  username            String?   @unique
  usernameUpdatedAt   DateTime?
  isPublic            Boolean   @default(true)
  bio                 String?
  avatarUrl           String?
  displayName         String?
  githubUsername      String?
  linkedinUrl         String?
  portfolioUrl        String?
  socialLinks         String[]  @default([])
  coverLetterName     String?
  followersCount      Int       @default(0)
  followingCount      Int       @default(0)
  followersLastSeenAt DateTime?
  totalChallengeScore Int       @default(0)
  totalChallengeCount Int       @default(0)
  totalXp             Int       @default(0)
  level               Int       @default(1)
  roleType            String?
  roleTypeOther       String?
  experienceLevel     String?
  techStack           String[]  @default([])
  languages           String[]  @default([])
  onboardedAt         DateTime?
  onboardingSkipped   Boolean   @default(false)
  // ProfileDigest — generated once per user by a Haiku vision call, refreshed
  // when any source (CV hash, LinkedIn text, GitHub username, portfolio URL)
  // changes. The digest fuses all sources into a single compact synthesis
  // consumed by every analyze call → no need to re-process raw CV/LinkedIn/
  // GitHub on each analysis.
  digest              Json?
  digestUpdatedAt     DateTime?
  // SHA-256 hashes of each source's content, used to detect staleness
  // without re-fetching: { cv, linkedin, githubUsername, portfolioUrl }.
  digestSourceHashes  Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  followers     Follow[] @relation("FollowFollowing")
  following     Follow[] @relation("FollowFollower")
  blocksMade    Block[]  @relation("BlockBlocker")
  blocksAgainst Block[]  @relation("BlockBlocked")

  @@index([totalChallengeScore(sort: Desc)])
  @@index([totalXp(sort: Desc)])
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    Profile  @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   Profile  @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId, createdAt])
  @@index([followingId, createdAt])
}

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())
  blocker   Profile  @relation("BlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   Profile  @relation("BlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId, createdAt])
  @@index([blockedId])
}

model SavedCv {
  id        Int      @id @default(autoincrement())
  email     String
  name      String
  url       String
  createdAt DateTime @default(now())

  @@index([email])
  // Covers GET /api/analyze/saved-cvs (WHERE email = ? ORDER BY createdAt DESC).
  @@index([email, createdAt(sort: Desc)])
}

model InterviewAttempt {
  id             Int      @id @default(autoincrement())
  email          String
  analysisId     Int
  analysisRecord Analysis @relation(fields: [analysisId], references: [id])
  transcript     Json // [{ role: 'ai'|'user', content: string, questionIndex: number }]
  analysis       Json? // null until /complete is called
  createdAt      DateTime @default(now())

  @@index([email])
  @@index([analysisId])
  // Covers interview history listings (WHERE email = ? ORDER BY createdAt DESC).
  @@index([email, createdAt(sort: Desc)])
}

model DailyChallenge {
  id            Int      @id @default(autoincrement())
  date          DateTime // UTC start-of-day for the day this challenge is active
  language      String   @default("typescript") // "typescript" | "python" | "java" (V1 only generates TS)
  title         String
  focusTag      String // see focus-tags.ts FOCUS_TAGS
  difficulty    String // "easy" | "medium" | "hard"
  snippet       String // the code to review
  question      String // markdown (paragraphs, inline `code`, **bold**)
  issues        Json // [{ title, description, severity }] — server-only
  whatToLookFor Json     @default("[]") // string[] — public watchpoints (3 items expected on new gen)
  hints         Json     @default("[]") // string[] — Socratic guiding questions (3 items expected on new gen)
  estimatedTime Int // in minutes
  createdAt     DateTime @default(now())

  attempts ChallengeAttempt[]

  @@unique([date, language])
}

model ChallengeAttempt {
  id             Int            @id @default(autoincrement())
  email          String
  challengeId    Int
  challenge      DailyChallenge @relation(fields: [challengeId], references: [id])
  firstAnswer    String
  secondAnswer   String?
  aiChallenge    String?
  score          Int            @default(0) // 0-100, populated on final submission
  scoreBreakdown Json           @default("{}") // { issues_found, explanation_quality, prioritization, bonus, feedback, missed_issues }
  completedAt    DateTime       @default(now())

  @@unique([email, challengeId])
  @@index([email])
  @@index([challengeId])
  @@index([challengeId, score(sort: Desc), completedAt])
  // Covers the user's challenge history endpoints
  // (WHERE email = ? ORDER BY completedAt DESC).
  @@index([email, completedAt(sort: Desc)])
}

model ChallengeStreak {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastCompletedAt DateTime?
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())

  @@index([currentStreak(sort: Desc)])
}

model XpLedger {
  id          Int      @id @default(autoincrement())
  email       String
  amount      Int // positive XP grant (negative reserved for future spend)
  reason      String // "challenge_completion" | "first_perfect_focus_tag" | "backfill_legacy"
  breakdown   Json? // optional multiplier breakdown for transparency
  attemptId   Int?
  challengeId Int?
  createdAt   DateTime @default(now())

  @@index([email, createdAt(sort: Desc)])
  @@index([attemptId])
}

model UnlockedReward {
  id                  Int       @id @default(autoincrement())
  email               String
  rewardKey           String // RewardKey from tier-config
  unlockedAt          DateTime  @default(now())
  unlockedAtLevel     Int
  redeemed            Boolean   @default(false)
  redeemedAt          DateTime?
  stripeCouponId      String? // null for cosmetic rewards
  stripePromotionCode String? // human-readable code shown to user

  @@unique([email, rewardKey])
  @@index([email])
}

// Append-only ledger for one-time analysis credits.
// Balance = sum(amount WHERE type='grant') - sum(amount WHERE type='consume').
// Grants come from Stripe purchases or admin actions; consumes come from
// analyses that overflowed the monthly cap. Credits never expire.
//
// Idempotency: `(type, referenceId)` is unique so a replayed Stripe webhook
// or a retried analysis consume cannot double-write.
model CreditLedger {
  id          Int                @id @default(autoincrement())
  email       String
  type        CreditLedgerType
  amount      Int // always positive; sign carried by `type`
  source      CreditLedgerSource
  // Grant: stripePaymentIntentId or admin tag.
  // Consume: analysisId stringified.
  referenceId String
  createdAt   DateTime           @default(now())

  @@unique([type, referenceId])
  @@index([email, createdAt(sort: Desc)])
}

enum EmailType {
  welcome
  analysis_ready
  drip_d1
  drip_d3
}

enum EmailCategory {
  transactional
  marketing
}

enum EmailStatus {
  queued
  sent
  delivered
  failed
  skipped
  bounced
  complained
}

// One row per outbound email. `dedupeKey` is unique, so enqueuing the same
// (type, recipient, context) twice is a no-op — DB-level idempotency on top of
// the BullMQ jobId. Status is advanced by the worker (sent/failed) and later by
// the Resend webhook (delivered/bounced/complained).
model EmailLog {
  id         Int           @id @default(autoincrement())
  email      String
  type       EmailType
  category   EmailCategory
  locale     String        @default("en")
  status     EmailStatus   @default(queued)
  dedupeKey  String        @unique
  providerId String?
  error      String?
  createdAt  DateTime      @default(now())
  sentAt     DateTime?

  @@index([email, type])
}

enum ScheduledEmailStatus {
  pending
  sent
  cancelled
}

// A future email (drips D1/D3). A cron scans `pending` rows whose `sendAfter`
// has passed, skips opted-out/converted recipients, then enqueues them. Unlike
// BullMQ delayed jobs this is inspectable, cancellable, and survives a Redis
// flush — and it works in dev without Redis.
model ScheduledEmail {
  id          Int                  @id @default(autoincrement())
  email       String
  type        EmailType
  locale      String               @default("en")
  sendAfter   DateTime
  status      ScheduledEmailStatus @default(pending)
  dedupeKey   String               @unique
  createdAt   DateTime             @default(now())
  processedAt DateTime?

  @@index([status, sendAfter])
}

enum SuppressionReason {
  unsubscribe // user opted out of marketing
  hard_bounce // address rejected — stop ALL mail
  complaint // marked as spam — stop ALL mail
  manual // added by an admin
}

// Do-not-send list, checked before every send. `unsubscribe` blocks marketing
// only; `hard_bounce`/`complaint` block everything. Populated by the unsubscribe
// route and (later) the Resend webhook.
model Suppression {
  id        Int               @id @default(autoincrement())
  email     String            @unique
  reason    SuppressionReason
  createdAt DateTime          @default(now())
}
