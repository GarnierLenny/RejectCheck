generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Waitlist {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Subscription {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  stripeCustomerId String
  plan             String
  status           String
  currentPeriodEnd DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Analysis {
  id               Int          @id @default(autoincrement())
  email            String?
  ip               String?
  jobDescription   String?
  result           Json?
  createdAt        DateTime     @default(now())
  cvText           String?
  motivationLetter String?
  jobLabel         String?
  company          String?
  Application      Application?
}

model Profile {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  username       String?
  avatarUrl      String?
  displayName    String?
  githubUsername String?
  linkedinUrl    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SavedCv {
  id        Int      @id @default(autoincrement())
  email     String
  name      String
  url       String
  createdAt DateTime @default(now())

  @@index([email])
}

model InterviewAttempt {
  id         Int      @id @default(autoincrement())
  email      String
  analysisId Int
  transcript Json
  analysis   Json?
  createdAt  DateTime @default(now())
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Application {
  id                Int       @id @default(autoincrement())
  email             String
  jobTitle          String
  company           String
  status            String    @default("applied")
  appliedAt         DateTime  @default(now())
  notes             String?
  analysisId        Int?      @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  companyStage      String?
  contractType      String?
  languagesRequired String?
  officeLocation    String?
  pay               String?
  seniority         String?
  workSetting       String?
  yearsOfExperience String?
  Analysis          Analysis? @relation(fields: [analysisId], references: [id])

  @@unique([email, jobTitle, company])
}
