generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionPlan {
  shortlisted
  hired
}

enum SubscriptionStatus {
  active
  canceled
  incomplete
  incomplete_expired
  past_due
  trialing
  unpaid
  paused
}

enum ApplicationStatus {
  interested
  applied
  interviewing
  offer
  rejected
}

model Waitlist {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Subscription {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  stripeCustomerId String
  plan             SubscriptionPlan
  status           SubscriptionStatus
  currentPeriodEnd DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([stripeCustomerId])
}

model Analysis {
  id               Int          @id @default(autoincrement())
  email            String?      // Registered users only
  ip               String?      // Anonymous tracking
  jobDescription   String?      // Registered users only
  jobLabel         String?      // User-defined label for easy identification
  company          String?      // AI-extracted company name
  jdLanguage       String?      // ISO 639-1 language code of job description
  cvText           String?      // Registered users only
  linkedinText     String?      // Registered users only
  githubInfo       String?      // Registered users only
  motivationLetter String?      // Registered users only
  coverLetter      String?      // Saved after HIRED-plan generation
  result           Json?        // Registered users only
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  application       Application?
  interviewAttempts InterviewAttempt[]

  @@index([email])
  @@index([ip])
}

model Application {
  id                  Int       @id @default(autoincrement())
  email               String
  jobTitle            String
  company             String
  status              ApplicationStatus @default(applied)
  appliedAt           DateTime  @default(now())
  notes               String?
  analysisId          Int?      @unique
  analysis            Analysis? @relation(fields: [analysisId], references: [id])
  seniority           String?
  pay                 String?
  officeLocation      String?
  workSetting         String?
  contractType        String?
  languagesRequired   String?
  yearsOfExperience   String?
  companyStage        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([email, jobTitle, company])
  @@index([email])
}

model Profile {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  username            String?   @unique
  usernameUpdatedAt   DateTime?
  isPublic            Boolean   @default(true)
  bio                 String?
  avatarUrl           String?
  displayName         String?
  githubUsername      String?
  linkedinUrl         String?
  portfolioUrl        String?
  socialLinks         String[]  @default([])
  coverLetterName     String?
  followersCount      Int       @default(0)
  followingCount      Int       @default(0)
  followersLastSeenAt DateTime?
  totalChallengeScore Int       @default(0)
  totalChallengeCount Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([totalChallengeScore(sort: Desc)])

  followers Follow[] @relation("FollowFollowing")
  following Follow[] @relation("FollowFollower")
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    Profile  @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   Profile  @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId, createdAt])
  @@index([followingId, createdAt])
}

model SavedCv {
  id        Int      @id @default(autoincrement())
  email     String
  name      String
  url       String
  createdAt DateTime @default(now())

  @@index([email])
}

model InterviewAttempt {
  id              Int      @id @default(autoincrement())
  email           String
  analysisId      Int
  analysisRecord  Analysis @relation(fields: [analysisId], references: [id])
  transcript      Json     // [{ role: 'ai'|'user', content: string, questionIndex: number }]
  analysis        Json?    // null until /complete is called
  createdAt       DateTime @default(now())

  @@index([email])
  @@index([analysisId])
}

model DailyChallenge {
  id            Int      @id @default(autoincrement())
  date          DateTime                   // UTC start-of-day for the day this challenge is active
  language      String   @default("typescript") // "typescript" | "python" | "java" (V1 only generates TS)
  title         String
  focusTag      String                     // see focus-tags.ts FOCUS_TAGS
  difficulty    String                     // "easy" | "medium" | "hard"
  snippet       String                     // the code to review
  question      String
  issues        Json                       // [{ title, description, severity }]
  estimatedTime Int                        // in minutes
  createdAt     DateTime @default(now())

  attempts ChallengeAttempt[]

  @@unique([date, language])
}

model ChallengeAttempt {
  id             Int            @id @default(autoincrement())
  email          String
  challengeId    Int
  challenge      DailyChallenge @relation(fields: [challengeId], references: [id])
  firstAnswer    String
  secondAnswer   String?
  aiChallenge    String?
  score          Int            @default(0) // 0-100, populated on final submission
  scoreBreakdown Json           @default("{}") // { issues_found, explanation_quality, prioritization, bonus, feedback, missed_issues }
  completedAt    DateTime       @default(now())

  @@unique([email, challengeId])
  @@index([email])
  @@index([challengeId])
  @@index([challengeId, score(sort: Desc), completedAt])
}

model ChallengeStreak {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastCompletedAt DateTime?
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())

  @@index([currentStreak(sort: Desc)])
}
