# Public Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Some Supabase newer setups expose a publishable key separately
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# API base URL — leave empty in dev (rewrite proxy in next.config.ts handles /api/*)
NEXT_PUBLIC_API_URL=

# Owner emails (comma-separated) — ONLY toggles the "audit mode" checkbox in the
# UI. The backend re-checks its own OWNER_EMAILS from the JWT, so this is not a
# security boundary; keep it in sync with the backend list.
NEXT_PUBLIC_OWNER_EMAILS=

# Observability (optional)
NEXT_PUBLIC_SENTRY_DSN=
