# Public Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Some Supabase newer setups expose a publishable key separately
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# API base URL — leave empty in dev (rewrite proxy in next.config.ts handles /api/*)
NEXT_PUBLIC_API_URL=

# Observability (optional)
NEXT_PUBLIC_SENTRY_DSN=
