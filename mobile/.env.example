# RejectCheck backend (NestJS) base URL.
#   - iOS simulator: http://localhost:8888
#   - Android emulator: http://10.0.2.2:8888
#   - Physical device: http://<your-LAN-IP>:8888 (same Wi-Fi) or a tunnel
#   - Prod: https://api.rejectcheck.com
EXPO_PUBLIC_API_URL=http://localhost:8888

# Supabase — SAME project as the web app (Project Settings → API).
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
